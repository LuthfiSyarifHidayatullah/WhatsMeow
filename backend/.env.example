APP_NAME="MPP Chatbot Bengkayang"
APP_ENV=local
APP_KEY=base64:GENERATE_NEW_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ============================================================
# DATABASE
# ============================================================
# Opsi 1: SQLite (MUDAH, tanpa install MySQL)
DB_CONNECTION=sqlite
# File: database/database.sqlite (buat manual: touch database/database.sqlite)

# Opsi 2: MySQL (untuk production)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=mpp_chatbot
# DB_USERNAME=root
# DB_PASSWORD=

# ============================================================
# BROADCAST / WEBSOCKET
# ============================================================
BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

PUSHER_APP_ID=mpp-local
PUSHER_APP_KEY=mpp-local-key
PUSHER_APP_SECRET=mpp-local-secret
PUSHER_HOST=127.0.0.1
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# ============================================================
# BOT CONFIG
# ============================================================
# Token harus sama dengan API_TOKEN di bot/.env
BOT_API_TOKEN=mpp-bot-secret-token-2024
# URL webhook Go bot (untuk mengirim pesan dari officer ke WA)
BOT_WEBHOOK_URL=http://localhost:8080
